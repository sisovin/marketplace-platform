            },
            "url": {
              "raw": "{{baseUrl}}/product/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["product", "{{productId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/product/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["product", "{{productId}}"]
            }
          },
          "response": []
        }
      ]
    },
    {
