          "response": []
        },
        {
          "name": "Delete Order",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/order/{{orderId}}",
              "host": ["{{baseUrl}}"],
              "path": ["order", "{{orderId}}"]
            }
          },
          "response": []
        }
      ]
    }
  ]
}
